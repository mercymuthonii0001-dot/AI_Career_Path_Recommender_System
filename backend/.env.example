# Django settings
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
DJANGO_USE_SQLITE=False
DB_SSL_REQUIRE=True
DATABASE_URL=postgresql://your_supabase_user:your_supabase_password@your_supabase_host:5432/postgres
ALLOWED_HOSTS=your-render-app.onrender.com,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://your-frontend-app.vercel.app,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\\.vercel\\.app$
CSRF_TRUSTED_ORIGINS=https://your-frontend-app.vercel.app,http://localhost:5173,http://127.0.0.1:5173
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Optional database overrides if you do not use DATABASE_URL
POSTGRES_DB=postgres
POSTGRES_USER=your_supabase_user
POSTGRES_PASSWORD=your_supabase_password
POSTGRES_HOST=your_supabase_host
POSTGRES_PORT=5432
